    select * from "tpch"."stg"."stg_tpch__orders"
),

lineitems as (
    select * from "tpch"."stg"."stg_tpch__lineitem"
),

joined as (
    select
        -- keys
        o.order_id,
        o.customer_id,
        l.part_id,
        l.supplier_id,
        l.line_number,

        -- order attributes
        o.order_date,
        o.order_status,
        o.order_priority,
        o.ship_priority,

        -- lineitem attributes
        l.quantity,
        l.extended_price,
        l.discount,
